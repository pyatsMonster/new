- name: Get full IPv4 routing table via FMG proxy
  environment:
    NO_PROXY: "*"
    no_proxy: "*"
  uri:
    url: "https://{{ FORTI_HOST }}/jsonrpc"
    method: POST
    validate_certs: false
    headers:
      Content-Type: "application/json"
      Authorization: "Bearer {{ FORTI_TOKEN }}"
    body_format: json
    body:
      method: "exec"
      params:
        - data:
            action: "get"
            resource: "/api/v2/monitor/router/ipv4"
            target: ["device/{{ inventory_hostname }}"]
            timeout: 60
          url: "/sys/proxy/json"
      id: 1
    return_content: yes
  register: routes_ipv4

- name: Show a few route fields
  debug:
    var: routes_ipv4.json.result[0].data[0].response.results


- name: Get IPsec tunnels via FMG proxy
  environment:
    NO_PROXY: "*"
    no_proxy: "*"
  uri:
    url: "https://{{ FORTI_HOST }}/jsonrpc"
    method: POST
    validate_certs: false
    headers:
      Content-Type: "application/json"
      Authorization: "Bearer {{ FORTI_TOKEN }}"
    body_format: json
    body:
      method: "exec"
      params:
        - data:
            action: "get"
            resource: "/api/v2/monitor/vpn/ipsec"
            target: ["device/{{ inventory_hostname }}"]
            timeout: 60
          url: "/sys/proxy/json"
      id: 2
    return_content: yes
  register: ipsec_tunnels

- name: View tunnels
  debug:
    var: ipsec_tunnels.json.result[0].data[0].response.results

- name: Store pre-upgrade routes and tunnels lists
  set_fact:
    routes_before_list: "{{ routes_ipv4.json.result[0].data[0].response.results | default([]) }}"
    tunnels_before_list: "{{ ipsec_tunnels.json.result[0].data[0].response.results | default([]) }}"
