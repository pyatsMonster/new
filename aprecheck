- name: Get detailed FortiGate information
  environment:
    NO_PROXY: "*"
    no_proxy: "*"
  uri:
    url: "https://{{ FORTI_HOST }}/jsonrpc"
    method: POST
    validate_certs: false
    headers:
      Content-Type: "application/json"
      Authorization: "Bearer {{ FORTI_TOKEN }}"
    body_format: json
    body:
      id: 1
      method: "get"
      params:
        - url: "/dvmdb/adom/{{ adom }}/device/{{ inventory_hostname }}"
          data:
            adom: "{{ adom }}"
    return_content: true
    use_proxy: false
  register: fortigate_details

- name: Initialize precheck assert tracking
  set_fact:
    precheck_assert_messages: []

- name: Store FortiGate information
  set_fact:
    fortigate_info:
      hostname: "{{ fortigate_details.json.result[0].data.hostname | default('N/A') }}"
      serial_number: "{{ fortigate_details.json.result[0].data.sn | default('N/A') }}"
      current_version: "{{ (fortigate_details.json.result[0].data.version | string)[0] }}.{{ fortigate_details.json.result[0].data.mr | string }}.{{ fortigate_details.json.result[0].data.patch | string }}"
      ip_address: "{{ fortigate_details.json.result[0].data.ip | default(FGT_HOST) }}"
      platform: "{{ fortigate_details.json.result[0].data.platform_str | default('N/A') }}"
      ha_mode: "{{ fortigate_details.json.result[0].data.ha_mode | default('standalone') }}"
      vdoms: "{{ fortigate_details.json.result[0].data.vdom | map(attribute='name') | list }}"

  when: 
    - fortigate_details is defined 
    - fortigate_details.json is defined 
    - fortigate_details.json.result[0].data is defined

